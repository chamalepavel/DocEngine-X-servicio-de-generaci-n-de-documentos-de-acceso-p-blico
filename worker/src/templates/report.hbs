<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; color: #2d3748; background: #fff; }

    .header {
      background: linear-gradient(135deg, #1a365d, #2b6cb0);
      color: white;
      padding: 36px 40px;
    }
    .header .tag {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: #bee3f8;
      margin-bottom: 10px;
    }
    .header h1 { font-size: 26px; font-weight: 700; }
    .header .meta {
      margin-top: 12px;
      font-size: 13px;
      color: #bee3f8;
      display: flex;
      gap: 30px;
    }

    .section { padding: 28px 40px; }
    .section-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: #2b6cb0;
      margin-bottom: 14px;
      border-left: 4px solid #2b6cb0;
      padding-left: 10px;
    }

    .summary-text {
      font-size: 14px;
      line-height: 1.7;
      color: #4a5568;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
      font-size: 14px;
    }
    thead tr { background: #2b6cb0; color: white; }
    thead th { padding: 11px 15px; text-align: left; }
    tbody tr:nth-child(even) { background: #ebf8ff; }
    tbody td { padding: 11px 15px; border-bottom: 1px solid #e2e8f0; }

    .conclusions {
      background: #f0fff4;
      border-left: 4px solid #38a169;
      padding: 20px 24px;
      border-radius: 4px;
      font-size: 14px;
      line-height: 1.7;
      color: #276749;
    }

    .footer {
      background: #edf2f7;
      padding: 18px 40px;
      text-align: center;
      font-size: 12px;
      color: #718096;
      margin-top: 30px;
    }
  </style>
</head>
<body>

  <!-- Encabezado -->
  <div class="header">
    <div class="tag">Reporte Técnico · DocEngine-X</div>
    <h1>{{title}}</h1>
    <div class="meta">
      <span>Autor: {{author}}</span>
      <span>Fecha: {{date}}</span>
      <span>Área: {{area}}</span>
    </div>
  </div>

  <!-- Resumen ejecutivo -->
  {{#if summary}}
  <div class="section">
    <div class="section-title">Resumen</div>
    <p class="summary-text">{{summary}}</p>
  </div>
  {{/if}}

  <!-- Tabla de datos -->
  {{#if data}}
  <div class="section">
    <div class="section-title">Datos del Reporte</div>
    <table>
      <thead>
        <tr>
          <th>Categoría</th>
          <th>Valor</th>
          <th>Observaciones</th>
        </tr>
      </thead>
      <tbody>
        {{#each data}}
        <tr>
          <td>{{this.category}}</td>
          <td>{{this.value}}</td>
          <td>{{this.notes}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  <!-- Conclusiones -->
  {{#if conclusions}}
  <div class="section">
    <div class="section-title">Conclusiones</div>
    <div class="conclusions">{{conclusions}}</div>
  </div>
  {{/if}}

  <div class="footer">
    Documento generado automáticamente por DocEngine-X · Universidad Galileo
  </div>

</body>
</html>
